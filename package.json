{
  "name": "vedaai-assessment-creator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:backend": "npm run dev -w @vedaai/backend",
    "dev:frontend": "npm run dev -w @vedaai/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.5.2"
}
